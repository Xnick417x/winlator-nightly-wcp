-#define jay_foreach_killed(I, s, c)                                            \
-   for (unsigned _kill_idx = 0; _kill_idx == 0; _kill_idx = 1)                 \
-      jay_foreach_src_index(I, s, c, idx)                                      \
-         for (unsigned _k = _kill_idx++; _k != ~0; _k = ~0)                    \
-            if (BITSET_TEST(I->last_use, _k))

-
-class LowerPostRA : public testing::Test {
- protected:
-   LowerPostRA()
-   {
-      mem_ctx = ralloc_context(NULL);
-
-      x = jay_bare_reg(GPR, 1);
-      y = jay_bare_reg(GPR, 2);
-      z = jay_bare_reg(GPR, 3);
-      u4 = jay_bare_reg(UGPR, 4);

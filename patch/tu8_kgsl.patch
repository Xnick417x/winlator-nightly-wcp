-jay_test_builder(void *memctx)
-{
-   jay_shader *s = jay_new_shader(memctx, MESA_SHADER_COMPUTE);
-   jay_function *f = jay_new_function(s);
-   s->partition.base8 = 8;
-
-   struct intel_device_info *devinfo =

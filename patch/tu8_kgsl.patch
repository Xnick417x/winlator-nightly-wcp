-    has_dest: bool
-    num_srcs: int
-    types: list[str]
-    negate: int
-    sat: bool
-    cmod: bool
-    side_effects: bool
-    _2src_commutative: bool
-    extra_struct: list[tuple[str, str]]
-
-
-@enum.unique
-class Props(enum.IntEnum):
-    NEGATE0 = 1 << 0
-    NEGATE1 = 1 << 1
-    NEGATE2 = 1 << 2
-    NEGATE3 = 1 << 3
-    SAT = 1 << 4
-    CMOD = 1 << 5
-    SIDE_EFFECTS = 1 << 6
-    COMMUTATIVE = 1 << 7
-    NO_DEST_ = 1 << 8
-    NEGATE = NEGATE0 | NEGATE1 | NEGATE2 | NEGATE3
-    NO_DEST = SIDE_EFFECTS | NO_DEST_
-
-
-_opcodes: dict[str, Opcode] = {}
-

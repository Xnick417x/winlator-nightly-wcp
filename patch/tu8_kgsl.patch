-static void
-jay_emit_if(struct nir_to_jay_state *nj, nir_if *nif)
-{
-   jay_builder *b = &nj->bld;
-   jay_def condition = nj_src(nif->condition);
-
-   jay_block *before_block = nj->current_block;
-   jay_block *after_block = jay_create_block(nj);

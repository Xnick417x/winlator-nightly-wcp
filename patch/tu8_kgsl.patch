-
-#define OP3_SWAP(jay, hw)                                                      \
-   case JAY_OPCODE_##jay:                                                      \
-      brw_alu3(p, BRW_OPCODE_##hw, dst, SRC(2), SRC(1), SRC(0));               \
-      break;

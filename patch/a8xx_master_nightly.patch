-
-   index += util_bitcount64(masks[location_mask_index] & BITFIELD64_MASK(location));
-
-#if 0 /* useful debug code */
-   printf("location_mask_index=%u\n", location_mask_index);
-   for (unsigned i = 0; i <= location_mask_index; i++)

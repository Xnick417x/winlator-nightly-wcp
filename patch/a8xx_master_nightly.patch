-      [MASK_MAYBE_PRIM_PRIM] = mask_maybe_per_prim,
-      [MASK_PER_PRIM] = mask_per_prim,
-      [MASK16_PER_PRIM] = mask16_per_prim,
-      [BACK_COLOR_MASK] = back_color_mask,
-      [PARAM_GEN_MASK] = 0,

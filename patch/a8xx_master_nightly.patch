-   }
-
-   enum {
-      MASK,
-      MASK16,
-      MASK_MAYBE_PRIM_PRIM, /* always after per-vertex varyings (NUM_INTERP) */
-      MASK_PER_PRIM,
-      MASK16_PER_PRIM,
-      BACK_COLOR_MASK, /* always after all other varyings */
-      PARAM_GEN_MASK, /* PARAM_GEN is loaded at location (NUM_INTERP + NUM_PRIM_INTERP). */
